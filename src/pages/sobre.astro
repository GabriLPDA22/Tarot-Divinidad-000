---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import DecoArt from "../components/DecoArt.astro";
---

<BaseLayout title="Sobre nosotros — Tarot Divinidad 000">
  <Header />

  <!-- ═══════════ HERO ═══════════ -->
  <section class="relative flex min-h-[65vh] flex-col items-center justify-center overflow-hidden bg-brand-bg px-6 pt-32 pb-20 text-center sm:pt-36 md:min-h-[60vh] md:pt-44 md:pb-24 lg:pt-48">
    <DecoArt variant="sun-moon" class="left-[-5rem] top-[8%] z-[0] h-[200px] w-[200px] sm:left-[-3rem] sm:h-[280px] sm:w-[280px] md:h-[380px] md:w-[380px]" opacity={0.05} />
    <DecoArt variant="crystal-ball" class="right-[-5rem] bottom-[5%] z-[0] h-[200px] w-[200px] sm:right-[-3rem] sm:h-[280px] sm:w-[280px] md:h-[380px] md:w-[380px]" opacity={0.05} />

    <div class="relative z-10 mx-auto max-w-2xl">
      <!-- Mystic eye -->
      <div class="mx-auto mb-8 md:mb-10" aria-hidden="true">
        <svg class="mx-auto h-14 w-14 text-brand-gold/20 sm:h-16 sm:w-16" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M30 12 L42 30 L30 48 L18 30 Z" stroke-width="1.2"/>
          <path d="M12 30 Q30 16 48 30 Q30 44 12 30 Z"/>
          <circle cx="30" cy="30" r="6"/>
          <circle cx="30" cy="30" r="2" fill="currentColor" stroke="none"/>
          <line x1="30" y1="4" x2="30" y2="9" opacity="0.4"/>
          <line x1="30" y1="51" x2="30" y2="56" opacity="0.4"/>
        </svg>
      </div>

      <h1 class="font-heading text-sm font-semibold uppercase tracking-[0.2em] text-brand-gold sm:text-base sm:tracking-[0.25em] md:text-lg">
        Acompañamiento consciente
      </h1>

      <div class="mx-auto mt-5 flex items-center justify-center gap-4" aria-hidden="true">
        <span class="h-px w-10 bg-gradient-to-r from-transparent to-brand-gold/25 sm:w-14"></span>
        <svg class="h-3 w-3 text-brand-gold/40" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z"/></svg>
        <span class="h-px w-10 bg-gradient-to-l from-transparent to-brand-gold/25 sm:w-14"></span>
      </div>

      <p class="mx-auto mt-7 max-w-md text-sm leading-[1.9] text-brand-text/55 sm:mt-8 sm:max-w-lg sm:text-base md:mt-10 md:text-lg md:leading-[1.85]">
        No buscamos imponer respuestas.<br class="hidden sm:inline" />
        Creamos un espacio de claridad, escucha y orientación para acompañarte en momentos de decisión.
      </p>
    </div>
  </section>

  <!-- ═══════════ CITA ═══════════ -->
  <section class="relative bg-brand-bg py-10 md:py-14">
    <div class="mx-auto max-w-xl px-6 text-center">
      <blockquote>
        <p class="font-heading text-base italic leading-relaxed text-brand-gold/50 sm:text-lg md:text-xl">
          "El tarot no revela el destino.<br />Revela lo que ya sabes."
        </p>
      </blockquote>
    </div>
  </section>

  <!-- ═══════════ NUESTRO ENFOQUE ═══════════ -->
  <section class="relative overflow-hidden bg-brand-bg py-20 md:py-28">
    <DecoArt variant="lotus" class="right-[-4rem] top-[10%] z-[0] h-[220px] w-[220px] sm:right-[-2rem] sm:h-[300px] sm:w-[300px] md:h-[400px] md:w-[400px]" opacity={0.05} />

    <div class="relative z-10 mx-auto max-w-5xl px-6 md:px-8">
      <h2 class="text-center font-heading text-xs font-semibold uppercase tracking-[0.2em] text-brand-gold sm:text-sm sm:tracking-[0.25em]">
        Nuestro enfoque
      </h2>

      <div class="mx-auto mt-4 flex items-center justify-center gap-3" aria-hidden="true">
        <span class="h-px w-8 bg-brand-gold/15"></span>
        <span class="h-1 w-1 rounded-full bg-brand-gold/25"></span>
        <span class="h-px w-8 bg-brand-gold/15"></span>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-3 md:mt-14 md:gap-6">
        {([
          { title: "Escucha", text: "El tarot como herramienta de reflexión, no de dependencia. Un espejo que acompaña, no un oráculo que dicta.", icon: "ear" },
          { title: "Claridad", text: "Un espacio para ordenar pensamientos y emociones. Para ver lo que el ruido del día a día no deja ver.", icon: "eye" },
          { title: "Decisión", text: "Acompañamos procesos, no dirigimos caminos. La última palabra siempre es tuya.", icon: "compass" },
        ] as const).map((card) => (
          <article class="group relative overflow-hidden rounded-lg border border-brand-gold/10 bg-[#09090f] p-6 text-center transition-all duration-500 hover:border-brand-gold/25 hover:shadow-[0_0_40px_-10px_rgba(184,162,106,0.10)] sm:p-7 md:p-8">
            <div class="pointer-events-none absolute inset-[4px] rounded-[4px] border border-brand-gold/5 transition-all duration-500 group-hover:border-brand-gold/10" aria-hidden="true"></div>

            <svg class="pointer-events-none absolute top-2 left-2 h-3 w-3 text-brand-gold/12 transition-colors group-hover:text-brand-gold/25" aria-hidden="true"><path d="M0 10 L0 0 L10 0" fill="none" stroke="currentColor" stroke-width="1"/></svg>
            <svg class="pointer-events-none absolute right-2 bottom-2 h-3 w-3 text-brand-gold/12 transition-colors group-hover:text-brand-gold/25" aria-hidden="true"><path d="M12 2 L12 12 L2 12" fill="none" stroke="currentColor" stroke-width="1"/></svg>

            <div class="relative z-10 mx-auto mb-5 flex h-11 w-11 items-center justify-center rounded-full border border-brand-gold/15 bg-brand-gold/5 text-brand-gold/70 transition-all duration-500 group-hover:bg-brand-gold/10 group-hover:text-brand-gold group-hover:shadow-[0_0_16px_-6px_rgba(184,162,106,0.3)]">
              {card.icon === "ear" && (
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 8.5a6.5 6.5 0 1 1 13 0c0 6-6 6.5-6 10.5"/><circle cx="13" cy="22" r="1" fill="currentColor"/>
                </svg>
              )}
              {card.icon === "eye" && (
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
              )}
              {card.icon === "compass" && (
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
                </svg>
              )}
            </div>

            <h3 class="relative z-10 mb-3 font-heading text-sm font-semibold tracking-wider text-brand-text sm:text-base">{card.title}</h3>
            <p class="relative z-10 text-xs leading-[1.8] text-brand-text/50 sm:text-sm">{card.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ CÓMO ES UNA CONSULTA ═══════════ -->
  <section class="relative overflow-hidden bg-brand-bg py-20 md:py-28">
    <DecoArt variant="cards" class="left-[-4rem] top-[5%] z-[0] h-[250px] w-[250px] sm:left-[-2rem] sm:h-[320px] sm:w-[320px] md:h-[420px] md:w-[420px]" opacity={0.05} />

    <div class="relative z-10 mx-auto max-w-2xl px-6 text-center md:px-8">
      <h2 class="font-heading text-xs font-semibold uppercase tracking-[0.2em] text-brand-gold sm:text-sm sm:tracking-[0.25em]">
        Cómo es una consulta
      </h2>

      <div class="mx-auto mt-4 flex items-center justify-center gap-3" aria-hidden="true">
        <span class="h-px w-8 bg-brand-gold/15"></span>
        <span class="h-1 w-1 rounded-full bg-brand-gold/25"></span>
        <span class="h-px w-8 bg-brand-gold/15"></span>
      </div>

      <!-- Steps -->
      <div class="mt-12 space-y-6 text-left md:mt-14">
        {([
          { step: "01", title: "Conexión", text: "La consulta comienza con una breve conversación para entender tu momento actual y qué necesitas explorar." },
          { step: "02", title: "Lectura", text: "Se realiza la tirada por teléfono, en un ambiente de respeto y escucha. Cada carta se interpreta en relación a tu situación." },
          { step: "03", title: "Integración", text: "Al final, hacemos un resumen para que te lleves claridad práctica. No predicciones, sino herramientas para decidir." },
        ] as const).map((item) => (
          <div class="group flex gap-4 rounded-lg border border-brand-gold/8 bg-[#09090f] p-5 transition-all duration-300 hover:border-brand-gold/18 sm:gap-5 sm:p-6">
            <span class="shrink-0 font-heading text-2xl font-bold text-brand-gold/15 transition-colors group-hover:text-brand-gold/30 sm:text-3xl">{item.step}</span>
            <div>
              <h3 class="mb-1.5 font-heading text-sm font-semibold text-brand-text/80 sm:text-base">{item.title}</h3>
              <p class="text-xs leading-[1.8] text-brand-text/45 sm:text-sm">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ QUÉ NO HACEMOS ═══════════ -->
  <section class="relative overflow-hidden bg-brand-bg py-20 md:py-28">
    <DecoArt variant="key" class="right-[-4rem] bottom-[5%] z-[0] h-[220px] w-[220px] sm:right-[-2rem] sm:h-[300px] sm:w-[300px] md:h-[380px] md:w-[380px]" opacity={0.05} />

    <div class="relative z-10 mx-auto max-w-3xl px-6 md:px-8">
      <h2 class="text-center font-heading text-xs font-semibold uppercase tracking-[0.2em] text-brand-gold sm:text-sm sm:tracking-[0.25em]">
        Qué no hacemos
      </h2>

      <div class="mx-auto mt-4 flex items-center justify-center gap-3" aria-hidden="true">
        <span class="h-px w-8 bg-brand-gold/15"></span>
        <span class="h-1 w-1 rounded-full bg-brand-gold/25"></span>
        <span class="h-px w-8 bg-brand-gold/15"></span>
      </div>

      <p class="mx-auto mt-6 max-w-md text-center text-xs leading-relaxed text-brand-text/40 sm:text-sm">
        Nuestro compromiso es con la honestidad y el respeto a tu proceso.
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-3 md:mt-12">
        {([
          { text: "No imponemos decisiones", sub: "Tu libre albedrío es sagrado.", icon: "shield" },
          { text: "No generamos dependencia", sub: "Buscamos que vueles sola.", icon: "unlock" },
          { text: "No prometemos magia", sub: "Ofrecemos claridad, no fantasía.", icon: "circle" },
        ] as const).map((item) => (
          <div class="group flex flex-col items-center rounded-lg border border-brand-text/5 bg-[#09090f] p-5 text-center transition-all duration-400 hover:border-brand-gold/12 sm:p-6">
            <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-full border border-brand-text/8 text-brand-text/20 transition-all duration-400 group-hover:border-brand-gold/20 group-hover:text-brand-gold/40">
              {item.icon === "shield" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
              {item.icon === "unlock" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>
              )}
              {item.icon === "circle" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              )}
            </div>
            <p class="text-xs font-medium text-brand-text/55 sm:text-sm">{item.text}</p>
            <p class="mt-1.5 text-[11px] text-brand-text/30">{item.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ CITA FINAL ═══════════ -->
  <section class="bg-brand-bg py-10 md:py-14">
    <div class="mx-auto max-w-xl px-6 text-center">
      <blockquote>
        <p class="font-heading text-sm italic leading-relaxed text-brand-gold/35 sm:text-base md:text-lg">
          "No venimos a darte respuestas.<br />Venimos a ayudarte a escuchar las tuyas."
        </p>
      </blockquote>
    </div>
  </section>

  <!-- ═══════════ CTA FINAL ═══════════ -->
  <section class="relative overflow-hidden bg-brand-bg py-20 md:py-28">
    <div class="absolute top-0 left-1/2 h-px w-[40%] -translate-x-1/2 bg-gradient-to-r from-transparent via-brand-gold/12 to-transparent" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-md px-6 text-center">
      <div class="mx-auto mb-6 flex h-12 w-12 items-center justify-center rounded-full border border-brand-gold/15 sm:mb-8" aria-hidden="true">
        <svg class="h-5 w-5 text-brand-gold/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>

      <p class="font-heading text-lg font-bold text-brand-text sm:text-xl md:text-2xl">
        ¿Preparada para tu consulta?
      </p>
      <p class="mx-auto mt-3 max-w-xs text-xs text-brand-text/40 sm:text-sm">
        Elige la tirada que mejor se adapte a lo que necesitas ahora.
      </p>
      <a href="/reservar" class="btn-primary mt-7 inline-flex sm:mt-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Reservar consulta
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
