---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Página no encontrada — Tarot Divinidad 000">
  <Header />
  <main class="relative flex min-h-[80vh] flex-col items-center justify-center bg-brand-bg px-6 text-center">
    <!-- Decorative symbol -->
    <div class="mb-8 animate-pulse" aria-hidden="true">
      <svg class="mx-auto h-24 w-24 text-brand-gold/20 sm:h-32 sm:w-32" viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <path d="M60 10 L80 50 L60 90 L40 50 Z" stroke-width="1.5"/>
        <path d="M30 50 Q60 30 90 50 Q60 70 30 50 Z"/>
        <circle cx="60" cy="50" r="8"/>
        <circle cx="60" cy="50" r="2.5" fill="currentColor" stroke="none"/>
        <line x1="60" y1="90" x2="60" y2="110" stroke-dasharray="2 4"/>
        <circle cx="60" cy="114" r="2" fill="currentColor" stroke="none" opacity="0.5"/>
      </svg>
    </div>

    <p class="font-heading text-6xl font-bold tracking-wider text-brand-gold/30 sm:text-7xl">
      404
    </p>

    <h1 class="mt-4 font-heading text-lg font-semibold uppercase tracking-[0.2em] text-brand-text/80 sm:text-xl">
      Las cartas no revelan este camino
    </h1>

    <p class="mx-auto mt-4 max-w-sm text-sm leading-relaxed text-brand-text/40 sm:text-base">
      La página que buscas no existe o ha sido movida. Quizá el universo te está guiando hacia otro lugar.
    </p>

    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:gap-4">
      <a href="/" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Volver al inicio
      </a>
      <a href="/reservar" class="btn-secondary">
        Reservar consulta
      </a>
    </div>

    <!-- Ambient dots -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-[20%] left-[15%] h-1 w-1 rounded-full bg-brand-gold/10"></div>
      <div class="absolute top-[35%] right-[20%] h-1.5 w-1.5 rounded-full bg-brand-gold/8"></div>
      <div class="absolute bottom-[25%] left-[25%] h-1 w-1 rounded-full bg-brand-gold/10"></div>
      <div class="absolute bottom-[40%] right-[12%] h-1 w-1 rounded-full bg-brand-gold/6"></div>
    </div>
  </main>
  <Footer />
</BaseLayout>
