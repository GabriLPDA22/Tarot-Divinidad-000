---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Error del servidor — Tarot Divinidad 000">
  <Header />
  <main class="relative flex min-h-[80vh] flex-col items-center justify-center bg-brand-bg px-6 text-center">
    <!-- Broken crystal ball symbol -->
    <div class="mb-8" aria-hidden="true">
      <svg class="mx-auto h-24 w-24 text-brand-gold/20 sm:h-32 sm:w-32" viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="60" cy="55" r="35" stroke-width="1.5"/>
        <circle cx="60" cy="55" r="28" stroke-dasharray="3 6" opacity="0.4"/>
        <path d="M48 45 L55 60 L45 70" stroke-width="1.5" opacity="0.6"/>
        <path d="M72 42 L65 55 L75 65" stroke-width="1.5" opacity="0.6"/>
        <path d="M58 38 L60 52 L62 38" stroke-width="1" opacity="0.4"/>
        <path d="M35 90 L50 80 L70 80 L85 90" stroke-width="1.5"/>
        <path d="M40 90 L80 90" stroke-width="1.5"/>
        <circle cx="60" cy="55" r="4" fill="currentColor" stroke="none" opacity="0.3"/>
      </svg>
    </div>

    <p class="font-heading text-6xl font-bold tracking-wider text-brand-gold/30 sm:text-7xl">
      500
    </p>

    <h1 class="mt-4 font-heading text-lg font-semibold uppercase tracking-[0.2em] text-brand-text/80 sm:text-xl">
      Las energías se han desalineado
    </h1>

    <p class="mx-auto mt-4 max-w-sm text-sm leading-relaxed text-brand-text/40 sm:text-base">
      Algo inesperado ha ocurrido en nuestro servidor. Estamos trabajando para restablecer la conexión.
    </p>

    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:gap-4">
      <a href="/" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Volver al inicio
      </a>
      <button onclick="location.reload()" class="btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
        Reintentar
      </button>
    </div>
  </main>
  <Footer />
</BaseLayout>
