---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { DecoVariant } from "../components/DecoArt.astro";
import DecoArt from "../components/DecoArt.astro";

interface Props {
  title: string;
  heading: string;
  decoLeft?: DecoVariant;
  decoRight?: DecoVariant;
}

const { title, heading, decoLeft, decoRight } = Astro.props;
---

<BaseLayout title={`${title} — Tarot Divinidad 000`}>
  <Header />
  <main class="relative min-h-screen overflow-hidden bg-brand-bg pt-36 pb-20 sm:pt-40 md:pt-44 md:pb-28 lg:pt-48 2xl:pt-52 3xl:pt-60 3xl:pb-36">
    {decoLeft && (
      <DecoArt
        variant={decoLeft}
        class="left-[-3rem] top-[10%] z-[0] h-[300px] w-[300px] md:left-[-1rem] md:h-[400px] md:w-[400px] 3xl:h-[520px] 3xl:w-[520px]"
        opacity={0.07}
      />
    )}
    {decoRight && (
      <DecoArt
        variant={decoRight}
        class="right-[-3rem] bottom-[10%] z-[0] h-[300px] w-[300px] md:right-[-1rem] md:h-[400px] md:w-[400px] 3xl:h-[520px] 3xl:w-[520px]"
        opacity={0.07}
      />
    )}

    <div class="relative z-10 mx-auto max-w-3xl px-6 md:px-8 3xl:max-w-4xl 3xl:px-12">
      <!-- Title -->
      <h1 class="text-center font-heading text-sm font-semibold uppercase tracking-[0.25em] text-brand-gold md:text-base 3xl:text-lg">
        {heading}
      </h1>

      <!-- Divider -->
      <div class="mx-auto mt-5 flex items-center justify-center gap-4" aria-hidden="true">
        <span class="h-px w-12 bg-gradient-to-r from-transparent to-brand-gold/30"></span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 text-brand-gold/60" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z"/>
          <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
        </svg>
        <span class="h-px w-12 bg-gradient-to-l from-transparent to-brand-gold/30"></span>
      </div>

      <!-- Content -->
      <article class="legal-content mt-12 md:mt-16 3xl:mt-20">
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal-content :global(h2) {
    font-family: "Montserrat", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #C7A85A;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .legal-content :global(h3) {
    font-family: "Montserrat", sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: #F4EEE6;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .legal-content :global(p) {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: rgba(244, 238, 230, 0.72);
    margin-bottom: 1rem;
  }

  .legal-content :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1rem;
  }

  .legal-content :global(li) {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: rgba(244, 238, 230, 0.68);
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.35rem;
  }

  .legal-content :global(li::before) {
    content: "◇";
    position: absolute;
    left: 0;
    color: rgba(199, 168, 90, 0.5);
    font-size: 0.7rem;
    top: 0.2rem;
  }

  .legal-content :global(a) {
    color: #C7A85A;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(199, 168, 90, 0.3);
    transition: text-decoration-color 0.3s;
  }

  .legal-content :global(a:hover) {
    text-decoration-color: #C7A85A;
  }

  .legal-content :global(strong) {
    color: rgba(244, 238, 230, 0.92);
    font-weight: 500;
  }

  @media (min-width: 2560px) {
    .legal-content :global(h2) { font-size: 1.15rem; }
    .legal-content :global(h3) { font-size: 1rem; }
    .legal-content :global(p),
    .legal-content :global(li) { font-size: 1.1rem; }
  }
</style>
