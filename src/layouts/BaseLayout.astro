---
import "../styles/global.css";
import FrameBorder from "../components/FrameBorder.astro";
import LoaderOverlay from "../components/LoaderOverlay.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { siteConfig } from "../content/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0B0B0F" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      (function(){
        function l(){var l=document.createElement("link");l.rel="stylesheet";l.href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Questrial&display=swap";document.head.appendChild(l);}
        if(document.readyState==="complete")l();else window.addEventListener("load",l);
      })();
    </script>
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Questrial&display=swap" />
    </noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-brand-bg text-brand-text font-body">
    <LoaderOverlay />
    <FrameBorder />
    <div class="relative z-[1]">
      <slot />
    </div>
    <CookieBanner />
    <script is:inline>
      (function () {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var elements = document.querySelectorAll("[data-parallax-el]");
        if (!elements.length) return;

        var ticking = false;
        function updateParallax() {
          var viewportH = window.innerHeight || document.documentElement.clientHeight;
          var rects = [];
          for (var i = 0; i < elements.length; i++) {
            rects.push(elements[i].getBoundingClientRect());
          }
          for (var i = 0; i < elements.length; i++) {
            var speed = parseFloat(elements[i].getAttribute("data-parallax-el") || "0.05");
            var rect = rects[i];
            var distanceFromCenter = rect.top + rect.height / 2 - viewportH / 2;
            var offset = -distanceFromCenter * speed;
            elements[i].style.setProperty("--parallax-offset", offset + "px");
          }
          ticking = false;
        }

        function requestUpdate() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(updateParallax);
        }

        function initParallax() {
          window.addEventListener("scroll", requestUpdate, { passive: true });
          window.addEventListener("resize", requestUpdate, { passive: true });
          updateParallax();
        }

        function runWhenIdle() {
          if ("requestIdleCallback" in window) {
            requestIdleCallback(function(){ initParallax(); }, { timeout: 2000 });
          } else {
            setTimeout(initParallax, 1);
          }
        }

        if (document.readyState === "complete") {
          runWhenIdle();
        } else {
          window.addEventListener("load", runWhenIdle);
        }
      })();
    </script>
  </body>
</html>
