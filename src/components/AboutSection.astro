---
import DecoArt from "./DecoArt.astro";
---

<section class="relative overflow-hidden bg-brand-bg py-24 md:py-32 3xl:py-40" id="sobre-mi">
  <DecoArt
    variant="lotus"
    class="left-[-3rem] bottom-[5%] z-[1] h-[260px] w-[260px] md:left-[-1rem] md:h-[360px] md:w-[360px] 3xl:h-[480px] 3xl:w-[480px]"
    opacity={0.10}
  />

  <div class="relative z-10 mx-auto max-w-3xl px-6 text-center md:px-8 3xl:max-w-4xl 3xl:px-12">
    <h2 class="font-heading text-sm font-semibold uppercase tracking-[0.25em] text-brand-gold md:text-base 3xl:text-lg">
      Sobre el espacio
    </h2>

    <div class="mx-auto mt-5 flex items-center justify-center gap-4" aria-hidden="true">
      <span class="h-px w-12 bg-gradient-to-r from-transparent to-brand-gold/30"></span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 text-brand-gold/60" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z"/>
        <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
      </svg>
      <span class="h-px w-12 bg-gradient-to-l from-transparent to-brand-gold/30"></span>
    </div>

    <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-brand-text/75 md:mt-8 md:text-lg 3xl:mt-10 3xl:text-xl">
      Un espacio creado para acompañar procesos desde la escucha y la claridad.
    </p>

    <a href="/sobre" class="btn-secondary mt-10 inline-flex md:mt-12 3xl:mt-14">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
      </svg>
      Conocer más
    </a>
  </div>
</section>
