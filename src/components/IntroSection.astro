---
import DecoArt from "./DecoArt.astro";

const cards = [
  {
    title: "Claridad",
    text: "Comprende lo que estás viviendo con calma y perspectiva.",
    icon: "eye",
  },
  {
    title: "Autoconocimiento",
    text: "Escucha tu intuición y reconecta contigo.",
    icon: "moon",
  },
  {
    title: "Decisión",
    text: "Elige desde tu verdad, no desde el miedo.",
    icon: "star",
  },
] as const;
---

<section class="relative overflow-hidden bg-brand-bg py-20 md:py-28 3xl:py-36" id="enfoque">
  <!-- Decorative SVG (LEFT) — sol/luna: dualidad, parallax suave -->
  <DecoArt
    variant="sun-moon"
    class="left-[-3rem] top-1/2 z-[1] -translate-y-1/2 h-[300px] w-[300px] md:left-[-1rem] md:h-[400px] md:w-[400px] 3xl:h-[550px] 3xl:w-[550px]"
    opacity={0.10}
  />

  <div class="relative z-10 mx-auto max-w-6xl px-6 md:px-8 2xl:max-w-7xl 3xl:max-w-[90rem] 3xl:px-12" data-parallax-el="0.06">
    <!-- Section title -->
    <h2 class="text-center font-heading text-sm font-semibold uppercase tracking-[0.25em] text-brand-gold md:text-base 3xl:text-lg">
      Acompañamiento consciente
    </h2>

    <!-- Divider -->
    <div class="mx-auto mt-5 flex items-center justify-center gap-4" aria-hidden="true">
      <span class="h-px w-12 bg-gradient-to-r from-transparent to-brand-gold/30"></span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 text-brand-gold/60" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z"/>
        <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
      </svg>
      <span class="h-px w-12 bg-gradient-to-l from-transparent to-brand-gold/30"></span>
    </div>

    <!-- Paragraph -->
    <p class="mx-auto mt-6 max-w-xl text-center text-base leading-relaxed text-brand-text/85 md:mt-8 md:text-lg 3xl:mt-10 3xl:max-w-2xl 3xl:text-xl">
      No predecimos el futuro.<br />
      Facilitamos claridad, autoconocimiento y decisiones desde tu verdad.
    </p>

    <!-- Cards grid -->
    <div class="mt-14 grid gap-6 lg:grid-cols-3 md:mt-16 md:gap-8 3xl:mt-20" data-parallax-el="0.04">
      {cards.map((card) => (
        <article class="tarot-card group relative overflow-hidden rounded-lg border border-brand-gold/15 bg-[#0a0a11] p-7 transition-all duration-400 hover:border-brand-gold/35 hover:shadow-[0_0_30px_-8px_rgba(184,162,106,0.15)] md:p-8 3xl:p-10">
          <!-- Double border effect -->
          <div class="pointer-events-none absolute inset-[5px] rounded-[5px] border border-brand-gold/8 transition-all duration-400 group-hover:border-brand-gold/15" aria-hidden="true"></div>

          <!-- Corner accents -->
          <svg class="pointer-events-none absolute top-2 left-2 h-4 w-4 text-brand-gold/20 transition-colors duration-400 group-hover:text-brand-gold/40" aria-hidden="true">
            <path d="M0 12 L0 0 L12 0" fill="none" stroke="currentColor" stroke-width="1"/>
          </svg>
          <svg class="pointer-events-none absolute right-2 bottom-2 h-4 w-4 text-brand-gold/20 transition-colors duration-400 group-hover:text-brand-gold/40" aria-hidden="true">
            <path d="M16 4 L16 16 L4 16" fill="none" stroke="currentColor" stroke-width="1"/>
          </svg>

          <!-- Decorative tarot SVG watermark -->
          <div class="pointer-events-none absolute inset-0 z-[1] flex items-center justify-center opacity-[0.04] blur-[1px] transition-opacity duration-400 group-hover:opacity-[0.06]" style="transform: scale(1.3) translateY(10%);" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 300" fill="none" stroke="#B8A26A" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round" class="h-full w-auto">
              <rect x="0" y="0" width="180" height="300" rx="6"/>
              <rect x="12" y="12" width="156" height="276" rx="3" opacity="0.5"/>
              <path d="M12,35 L12,12 L35,12 M168,35 L168,12 L145,12 M12,265 L12,288 L35,288 M168,265 L168,288 L145,288" opacity="0.6"/>
              {card.icon === "eye" && (
                <g transform="translate(90, 150)">
                  <path d="M-40,0 C-40,-22 -20,-36 0,-36 C20,-36 40,-22 40,0 C40,22 20,36 0,36 C-20,36 -40,22 -40,0 Z"/>
                  <circle cx="0" cy="0" r="12"/>
                  <circle cx="0" cy="0" r="4" fill="#B8A26A"/>
                </g>
              )}
              {card.icon === "moon" && (
                <g transform="translate(90, 150)">
                  <path d="M10,-40 A40,40 0 1,0 10,40 A30,30 0 1,1 10,-40 Z"/>
                  <circle cx="-5" cy="-15" r="2" fill="#B8A26A"/>
                </g>
              )}
              {card.icon === "star" && (
                <g transform="translate(90, 150)">
                  <polygon points="0,-40 12,-12 42,-12 18,6 28,36 0,18 -28,36 -18,6 -42,-12 -12,-12"/>
                </g>
              )}
            </svg>
          </div>

          <!-- Icon circle (centered) -->
          <div class="relative z-10 mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full border border-brand-gold/25 bg-brand-gold/5 text-brand-gold transition-all duration-400 group-hover:bg-brand-gold/10 group-hover:shadow-[0_0_16px_-4px_rgba(184,162,106,0.3)] 3xl:h-16 3xl:w-16">
            {card.icon === "eye" && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 3xl:h-6 3xl:w-6">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            )}
            {card.icon === "moon" && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 3xl:h-6 3xl:w-6">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            )}
            {card.icon === "star" && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 3xl:h-6 3xl:w-6">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            )}
          </div>

          <!-- Title (centered) -->
          <h3 class="relative z-10 mb-2 text-center font-heading text-base font-semibold tracking-wide text-brand-text md:text-lg 3xl:text-xl">
            {card.title}
          </h3>

          <!-- Text (centered) -->
          <p class="relative z-10 text-center text-sm leading-relaxed text-brand-text/70 md:text-base 3xl:text-lg">
            {card.text}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
