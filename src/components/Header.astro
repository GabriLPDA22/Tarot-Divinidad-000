---
import { siteConfig } from "../content/site";
import Logo from "./Logo.astro";
---

<header id="main-header" class="header-base fixed top-0 right-0 left-0 z-[65]">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-2 sm:px-6 sm:py-3 md:px-10 md:py-3 2xl:max-w-[90rem] 2xl:px-14 2xl:py-4 3xl:px-20 3xl:py-5">
    <Logo />

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 lg:flex 2xl:gap-11 3xl:gap-14" aria-label="Navegación principal">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class="font-heading text-[11px] font-medium uppercase tracking-[0.18em] text-brand-text/60 transition-colors hover:text-brand-gold 2xl:text-xs 3xl:text-[13px]"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/reservar"
        class="btn-primary !px-6 !py-2 !text-[10px] !tracking-[0.2em] 2xl:!px-8 2xl:!py-2.5 2xl:!text-[11px] 3xl:!px-10 3xl:!py-3 3xl:!text-xs"
      >
        Reservar
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="relative z-[70] flex h-10 w-10 items-center justify-center lg:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <div id="burger-icon" class="flex w-5 flex-col gap-[5px]">
        <span class="burger-line block h-[1.5px] w-full bg-brand-text transition-all duration-300"></span>
        <span class="burger-line block h-[1.5px] w-full bg-brand-text transition-all duration-300"></span>
        <span class="burger-line block h-[1.5px] w-full bg-brand-text transition-all duration-300"></span>
      </div>
    </button>
  </div>

  <div class="header-line h-px w-full bg-gradient-to-r from-transparent via-brand-gold/15 to-transparent opacity-0 transition-opacity duration-400"></div>
</header>

<!-- Mobile menu: FUERA del header para evitar problemas de stacking context -->
<nav
  id="mobile-nav"
  class="invisible fixed inset-0 z-[60] flex flex-col items-center justify-center gap-7 bg-brand-bg opacity-0 transition-all duration-300 lg:hidden"
  aria-label="Menú móvil"
  aria-hidden="true"
>
  {siteConfig.nav.map((item) => (
    <a
      href={item.href}
      class="nav-link font-heading text-lg font-medium uppercase tracking-[0.25em] text-brand-text/70 transition-colors hover:text-brand-gold"
    >
      {item.label}
    </a>
  ))}

  <div class="mt-2 h-px w-10 bg-brand-gold/20" aria-hidden="true"></div>

  <a
    href="/reservar"
    class="btn-primary mt-1"
  >
    Reservar
  </a>
</nav>

<style>
  .header-base {
    background: transparent;
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease, box-shadow 0.4s ease;
  }

  #main-header.scrolled {
    background: rgba(11, 11, 15, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 0 rgba(184, 162, 106, 0.1);
  }

  #main-header.scrolled .header-line {
    opacity: 1;
  }

  /* Burger → X animation */
  .menu-open .burger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-open .burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-open .burger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile nav visible */
  #mobile-nav.open {
    visibility: visible;
    opacity: 1;
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const burgerIcon = document.getElementById("burger-icon")!;
  const mobileNav = document.getElementById("mobile-nav")!;
  const header = document.getElementById("main-header")!;
  const navLinks = mobileNav.querySelectorAll("a");

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    mobileNav.classList.add("open");
    mobileNav.setAttribute("aria-hidden", "false");
    burgerIcon.classList.add("menu-open");
    toggle.setAttribute("aria-expanded", "true");
    toggle.setAttribute("aria-label", "Cerrar menú");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    isOpen = false;
    mobileNav.classList.remove("open");
    mobileNav.setAttribute("aria-hidden", "true");
    burgerIcon.classList.remove("menu-open");
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "Abrir menú");
    document.body.style.overflow = "";
  }

  toggle.addEventListener("click", () => (isOpen ? closeMenu() : openMenu()));
  navLinks.forEach((l) => l.addEventListener("click", closeMenu));

  window.addEventListener("scroll", () => {
    header.classList.toggle("scrolled", window.scrollY > 40);
  }, { passive: true });
</script>
