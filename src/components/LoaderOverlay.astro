---
interface Props {
  duration?: number;
}
// 2.8s para dar tiempo a apreciar el símbolo antes del salto
const { duration = 2800 } = Astro.props;
---

<noscript>
  <style>
    .loader-overlay { display: none !important; }
  </style>
</noscript>

<div
  class="loader-overlay fixed inset-0 z-[9999] bg-transparent"
  aria-hidden="true"
>
  <div class="absolute inset-0 flex items-center justify-center overflow-hidden">
    
    <svg viewBox="0 0 100 100" class="portal-svg absolute w-[180px] h-[180px] md:w-[250px] md:h-[250px] overflow-visible">
      
      <path d="M -5000 -5000 L 5100 -5000 L 5100 5100 L -5000 5100 Z 
               M 10 50 C 30 20 70 20 90 50 C 70 80 30 80 10 50 Z
               M 50 50 m -7 0 a 7 7 0 1 0 14 0 a 7 7 0 1 0 -14 0" 
            fill="#06060a" fill-rule="evenodd" />

      <g fill="none" stroke="#B8A26A" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M 10 50 C 30 20 70 20 90 50 C 70 80 30 80 10 50 Z" />
        <circle cx="50" cy="50" r="10" opacity="0.5" stroke-dasharray="2 4" />
        <circle cx="50" cy="50" r="7" />
      </g>
            
    </svg>
    
  </div>

  <style>
    .portal-svg {
      transform-origin: center center;
      will-change: transform, opacity;
      /* Animación: pausa contemplativa -> zoom portal */
      animation: zoomEye 1.6s cubic-bezier(0.8, 0, 0.2, 1) forwards;
      animation-delay: 0.8s;
    }

    @keyframes zoomEye {
      0% { transform: scale(1); opacity: 1; }
      20% { transform: scale(1.05); } /* Pequeño latido antes de entrar */
      100% { transform: scale(160); opacity: 0; }
    }
  </style>
</div>

<script is:inline define:vars={{ duration }}>
  (function () {
    var el = document.querySelector(".loader-overlay");
    if (!el) return;

    var seen = sessionStorage.getItem("loader-seen");
    if (seen) {
      el.remove();
      return;
    }

    sessionStorage.setItem("loader-seen", "1");
    
    var previousOverflow = document.body.style.overflow;
    document.body.style.overflow = "hidden";

    var safeDuration = Math.max(duration - 400, 0);
    setTimeout(function () {
      el.style.pointerEvents = "none";
      document.body.style.overflow = previousOverflow;
      void document.body.offsetHeight;
    }, safeDuration);

    setTimeout(function () {
      document.dispatchEvent(new Event("loader:done"));
      el.remove();
    }, duration);
  })();
</script>
