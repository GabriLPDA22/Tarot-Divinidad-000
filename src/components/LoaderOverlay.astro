---
interface Props {
  duration?: number;
}
const { duration = 2500 } = Astro.props;
---

<noscript>
  <style>
    .loader-overlay { display: none !important; }
  </style>
</noscript>

<div
  class="loader-overlay"
  style="position:fixed;inset:0;z-index:9999;overflow:hidden;background:#0d0809"
  aria-hidden="true"
>
  <svg
    viewBox="0 0 100 100"
    class="portal-svg"
    style="position:fixed;top:50%;left:50%;width:140px;height:140px;overflow:visible;transform:translate(-50%,-50%)"
  >
    <g fill="none" stroke="#B8A26A" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M 10 50 C 30 20 70 20 90 50 C 70 80 30 80 10 50 Z" />
      <circle cx="50" cy="50" r="10" opacity="0.5" stroke-dasharray="2 4" />
      <circle cx="50" cy="50" r="7" />
    </g>
  </svg>

  <style>
    @media (min-width: 768px) {
      .portal-svg { width: 250px !important; height: 250px !important; }
    }

    .loader-overlay.is-active {
      animation: overlayFade 1s ease-out forwards;
      animation-delay: 1.2s;
    }

    .loader-overlay.is-active .portal-svg {
      animation: zoomEye 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      animation-delay: 0.8s;
    }

    @keyframes zoomEye {
      0% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
      100% { transform: translate(-50%, -50%) scale(30); opacity: 0; }
    }

    @keyframes overlayFade {
      to { opacity: 0; }
    }
  </style>
</div>

<script is:inline define:vars={{ duration }}>
  (function () {
    var el = document.querySelector(".loader-overlay");
    if (!el) return;

    var seen = sessionStorage.getItem("loader-seen");
    if (seen) {
      el.remove();
      return;
    }

    sessionStorage.setItem("loader-seen", "1");
    document.body.classList.add("loader-active");

    var isMobile = window.matchMedia("(max-width: 768px)").matches;
    var actualDuration = isMobile ? 2000 : duration;

    if (isMobile) {
      el.style.animationDelay = "1.0s";
      var svg = el.querySelector(".portal-svg");
      if (svg) {
        svg.style.animationDelay = "0.6s";
        svg.style.animationDuration = "1.0s";
      }
    }

    el.classList.add("is-active");

    var fadeStart = isMobile ? 1000 : 1200;
    setTimeout(function () {
      el.style.pointerEvents = "none";
      document.body.classList.remove("loader-active");
    }, fadeStart);

    setTimeout(function () {
      document.dispatchEvent(new Event("loader:done"));
      el.remove();
    }, actualDuration);
  })();
</script>
