---
interface Props {
  duration?: number;
}
// 2.8s para dar tiempo a apreciar el símbolo antes del salto
const { duration = 2800 } = Astro.props;
---

<noscript>
  <style>
    .loader-overlay { display: none !important; }
  </style>
</noscript>

<div
  class="loader-overlay fixed inset-0 z-[9999] overflow-hidden bg-transparent"
  aria-hidden="true"
>
  <svg viewBox="0 0 100 100" class="portal-svg absolute inset-0 m-auto w-[140px] h-[140px] md:w-[250px] md:h-[250px] overflow-visible">
    
    <path d="M -5000 -5000 L 5100 -5000 L 5100 5100 L -5000 5100 Z 
             M 10 50 C 30 20 70 20 90 50 C 70 80 30 80 10 50 Z
             M 50 50 m -7 0 a 7 7 0 1 0 14 0 a 7 7 0 1 0 -14 0" 
          fill="#06060a" fill-rule="evenodd" />

    <g fill="none" stroke="#B8A26A" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M 10 50 C 30 20 70 20 90 50 C 70 80 30 80 10 50 Z" />
      <circle cx="50" cy="50" r="10" opacity="0.5" stroke-dasharray="2 4" />
      <circle cx="50" cy="50" r="7" />
    </g>
          
  </svg>

  <style>
    .loader-overlay {
      opacity: 0;
      animation: loaderFadeIn 0.2s ease-out forwards;
    }

    .portal-svg {
      transform-origin: center center;
      will-change: transform, opacity;
      animation: zoomEye 1.6s cubic-bezier(0.8, 0, 0.2, 1) forwards;
      animation-delay: 0.8s;
    }

    @keyframes loaderFadeIn {
      to { opacity: 1; }
    }

    @keyframes zoomEye {
      0% { transform: scale(1); opacity: 1; }
      20% { transform: scale(1.05); }
      100% { transform: scale(160); opacity: 0; }
    }
  </style>
</div>

<script is:inline define:vars={{ duration }}>
  (function () {
    var el = document.querySelector(".loader-overlay");
    if (!el) return;

    var seen = sessionStorage.getItem("loader-seen");
    if (seen) {
      el.remove();
      return;
    }

    var isMobile = window.matchMedia("(max-width: 768px)").matches;
    var actualDuration = isMobile ? 2000 : duration;
    var animDelay = isMobile ? "0.5s" : "0.8s";
    var animDuration = isMobile ? "1.2s" : "1.6s";
    var svg = el.querySelector(".portal-svg");
    if (svg) {
      svg.style.animationDelay = animDelay;
      svg.style.animationDuration = animDuration;
    }

    sessionStorage.setItem("loader-seen", "1");
    document.body.classList.add("loader-active");

    var safeDuration = Math.max(actualDuration - 800, 0);
    setTimeout(function () {
      el.style.pointerEvents = "none";
      document.body.classList.remove("loader-active");
    }, safeDuration);

    setTimeout(function () {
      document.dispatchEvent(new Event("loader:done"));
      el.remove();
    }, actualDuration);
  })();
</script>
