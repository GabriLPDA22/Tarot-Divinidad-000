---
interface Props {
  opacity?: number;
}
const { opacity = 0.7 } = Astro.props;
---

<div
  class="pointer-events-none fixed inset-0 z-[50] hidden h-full w-full md:block"
  style={`opacity: ${opacity}`}
  aria-hidden="true"
>
  <!-- Top-left -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 200 200"
    fill="none"
    class="corner-svg absolute top-0 left-0"
  >
    <line x1="20" y1="20" x2="180" y2="20" stroke="#C7A85A" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="20" y1="20" x2="20" y2="180" stroke="#C7A85A" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="30" y1="30" x2="150" y2="30" stroke="#C7A85A" stroke-width="0.6" opacity="0.6" stroke-linecap="round"/>
    <line x1="30" y1="30" x2="30" y2="150" stroke="#C7A85A" stroke-width="0.6" opacity="0.6" stroke-linecap="round"/>
    <g class="corner-diamond">
      <path d="M 55 40 L 70 55 L 55 70 L 40 55 Z" stroke="#C7A85A" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
      <circle cx="55" cy="55" r="3" fill="#C7A85A"/>
    </g>
    <path d="M 20 120 A 100 100 0 0 0 120 20" stroke="#C7A85A" stroke-width="0.6" fill="none" stroke-dasharray="3 6"/>
    <circle cx="30" cy="135" r="1.5" fill="#C7A85A"/>
    <circle cx="135" cy="30" r="1.5" fill="#C7A85A"/>
  </svg>

  <!-- Top-right -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 200 200"
    fill="none"
    class="corner-svg absolute top-0 right-0"
    style="transform: scaleX(-1)"
  >
    <line x1="20" y1="20" x2="180" y2="20" stroke="#C7A85A" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="20" y1="20" x2="20" y2="180" stroke="#C7A85A" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="30" y1="30" x2="150" y2="30" stroke="#C7A85A" stroke-width="0.6" opacity="0.6" stroke-linecap="round"/>
    <line x1="30" y1="30" x2="30" y2="150" stroke="#C7A85A" stroke-width="0.6" opacity="0.6" stroke-linecap="round"/>
    <g class="corner-diamond">
      <path d="M 55 40 L 70 55 L 55 70 L 40 55 Z" stroke="#C7A85A" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
      <circle cx="55" cy="55" r="3" fill="#C7A85A"/>
    </g>
    <path d="M 20 120 A 100 100 0 0 0 120 20" stroke="#C7A85A" stroke-width="0.6" fill="none" stroke-dasharray="3 6"/>
    <circle cx="30" cy="135" r="1.5" fill="#C7A85A"/>
    <circle cx="135" cy="30" r="1.5" fill="#C7A85A"/>
  </svg>

  <!-- Bottom-left -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 200 200"
    fill="none"
    class="corner-svg absolute bottom-0 left-0"
    style="transform: scaleY(-1)"
  >
    <line x1="20" y1="20" x2="180" y2="20" stroke="#C7A85A" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="20" y1="20" x2="20" y2="180" stroke="#C7A85A" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="30" y1="30" x2="150" y2="30" stroke="#C7A85A" stroke-width="0.6" opacity="0.6" stroke-linecap="round"/>
    <line x1="30" y1="30" x2="30" y2="150" stroke="#C7A85A" stroke-width="0.6" opacity="0.6" stroke-linecap="round"/>
    <g class="corner-diamond">
      <path d="M 55 40 L 70 55 L 55 70 L 40 55 Z" stroke="#C7A85A" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
      <circle cx="55" cy="55" r="3" fill="#C7A85A"/>
    </g>
    <path d="M 20 120 A 100 100 0 0 0 120 20" stroke="#C7A85A" stroke-width="0.6" fill="none" stroke-dasharray="3 6"/>
    <circle cx="30" cy="135" r="1.5" fill="#C7A85A"/>
    <circle cx="135" cy="30" r="1.5" fill="#C7A85A"/>
  </svg>

  <!-- Bottom-right -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 200 200"
    fill="none"
    class="corner-svg absolute right-0 bottom-0"
    style="transform: scale(-1, -1)"
  >
    <line x1="20" y1="20" x2="180" y2="20" stroke="#C7A85A" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="20" y1="20" x2="20" y2="180" stroke="#C7A85A" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="30" y1="30" x2="150" y2="30" stroke="#C7A85A" stroke-width="0.6" opacity="0.6" stroke-linecap="round"/>
    <line x1="30" y1="30" x2="30" y2="150" stroke="#C7A85A" stroke-width="0.6" opacity="0.6" stroke-linecap="round"/>
    <g class="corner-diamond">
      <path d="M 55 40 L 70 55 L 55 70 L 40 55 Z" stroke="#C7A85A" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
      <circle cx="55" cy="55" r="3" fill="#C7A85A"/>
    </g>
    <path d="M 20 120 A 100 100 0 0 0 120 20" stroke="#C7A85A" stroke-width="0.6" fill="none" stroke-dasharray="3 6"/>
    <circle cx="30" cy="135" r="1.5" fill="#C7A85A"/>
    <circle cx="135" cy="30" r="1.5" fill="#C7A85A"/>
  </svg>
</div>

<style>
  .corner-diamond {
    animation: fb-pulse 5s infinite alternate ease-in-out;
  }

  @keyframes fb-pulse {
    0% { opacity: 0.5; }
    100% { opacity: 1; filter: drop-shadow(0 0 6px rgba(199,168,90,0.5)); }
  }

  /* Tablet / iPad (768–1023) */
  @media (min-width: 768px) {
    .corner-svg { width: 100px; height: 100px; }
  }

  /* Portátil (1024–1279) */
  @media (min-width: 1024px) {
    .corner-svg { width: 130px; height: 130px; }
  }

  /* Desktop medio (1280–1439) */
  @media (min-width: 1280px) {
    .corner-svg { width: 160px; height: 160px; }
  }

  /* Desktop 1440p (1440–1919) */
  @media (min-width: 1440px) {
    .corner-svg { width: 190px; height: 190px; }
  }

  /* Full HD 1920 (1920–2559) */
  @media (min-width: 1920px) {
    .corner-svg { width: 240px; height: 240px; }
  }

  /* 2K / QHD (2560+) */
  @media (min-width: 2560px) {
    .corner-svg { width: 320px; height: 320px; }
  }

  /* 4K (3840+) */
  @media (min-width: 3840px) {
    .corner-svg { width: 420px; height: 420px; }
  }
</style>
