---
interface Props {
  class?: string;
  centered?: boolean;
}
const { class: className = "", centered = false } = Astro.props;
const viewBox = centered ? "0 0 652 150" : "0 0 520 150";
---

<a
  href="/"
  class:list={["group block shrink-0 transition-opacity hover:opacity-85", className]}
  aria-label="Tarot Divinidad 000 — Inicio"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox={viewBox}
    class="h-11 w-auto sm:h-13 md:h-14 lg:h-[70px] 2xl:h-20 3xl:h-[100px]"
    aria-hidden="true"
  >
    <defs>
      <style>
        .logo-g  { stroke: #C7A85A; fill: none; stroke-linecap: round; stroke-linejoin: round; }
        .logo-gf { fill: #C7A85A; }
      </style>
      <clipPath id="icon-clip">
        <rect x="0" y="0" width="130" height="150"/>
      </clipPath>
    </defs>

    <!-- Trinqueta -->
    <image
      href="/images/trinqueta.png"
      x="-110" y="-80"
      width="350" height="350"
      style="mix-blend-mode: screen"
      clip-path="url(#icon-clip)"
    />

    <!-- Text -->
    <g transform="translate(145, 82)">
      <text x="0" y="-5" font-size="32" fill="#F4EEE6"
        font-family="'Montserrat', sans-serif" letter-spacing="5" font-weight="600">TAROT DIVINIDAD</text>
      <line x1="2" y1="12" x2="360" y2="12" class="logo-g" stroke-width="0.8" opacity="0.4"/>
      <circle cx="181" cy="12" r="2.5" class="logo-gf"/>
      <path d="M 175 12 L 181 8 L 187 12 L 181 16 Z" class="logo-gf"/>
      <text y="38" font-size="16" fill="#C7A85A"
        font-family="'Montserrat', sans-serif" font-weight="300" text-anchor="middle">
        <tspan x="151">0</tspan>
        <tspan x="181">0</tspan>
        <tspan x="211">0</tspan>
      </text>
    </g>
  </svg>
</a>
