---
import { siteConfig } from "../content/site";

const rawPhone = siteConfig.contact.phone;
const formattedPhone = rawPhone.length === 11
  ? `+${rawPhone.slice(0,2)} ${rawPhone.slice(2,5)} ${rawPhone.slice(5,8)} ${rawPhone.slice(8)}`
  : `+${rawPhone}`;
---

<footer class="relative overflow-hidden bg-[#050508]">
  <!-- Top ornamental border -->
  <div class="flex items-center justify-center px-6" aria-hidden="true">
    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-brand-gold/20 to-brand-gold/40"></div>
    <div class="relative mx-5 flex items-center justify-center">
      <svg class="h-5 w-5 text-brand-gold/40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M20 4 L26 16 L36 20 L26 24 L20 36 L14 24 L4 20 L14 16 Z"/>
        <circle cx="20" cy="20" r="3" fill="currentColor" opacity="0.6" stroke="none"/>
      </svg>
    </div>
    <div class="h-px flex-1 bg-gradient-to-l from-transparent via-brand-gold/20 to-brand-gold/40"></div>
  </div>

  <!-- Ambient glow -->
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_-5%,rgba(184,162,106,0.06)_0%,transparent_70%)]" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-xl px-6 pt-12 pb-8 text-center sm:pt-14 md:pt-16 md:pb-10">

    <!-- Mystic eye symbol -->
    <div class="mx-auto mb-6 flex items-center justify-center" aria-hidden="true">
      <svg class="h-10 w-10 text-brand-gold/25" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M30 10 L42 30 L30 50 L18 30 Z"/>
        <path d="M14 30 Q30 18 46 30 Q30 42 14 30 Z"/>
        <circle cx="30" cy="30" r="5"/>
        <circle cx="30" cy="30" r="1.5" fill="currentColor" stroke="none"/>
      </svg>
    </div>

    <!-- Brand -->
    <p class="font-heading text-sm font-semibold tracking-[0.15em] text-brand-text/90 sm:text-[15px] sm:tracking-[0.25em] md:text-lg md:tracking-[0.3em]">
      TAROT DIVINIDAD
    </p>
    <div class="mt-1.5 flex items-center justify-center gap-3">
      <span class="h-px w-4 bg-brand-gold/20"></span>
      <p class="font-heading text-[10px] tracking-[0.4em] text-brand-gold/60 sm:text-[11px] sm:tracking-[0.5em]">000</p>
      <span class="h-px w-4 bg-brand-gold/20"></span>
    </div>

    <!-- Tagline -->
    <p class="mt-4 text-xs italic leading-relaxed text-brand-text/30 sm:mt-5 sm:text-[13px]">
      La claridad no se impone. Se revela.
    </p>

    <!-- Nav -->
    <nav class="mt-7 grid grid-cols-2 gap-x-8 gap-y-3 sm:mt-9 sm:flex sm:items-center sm:justify-center sm:gap-x-3 sm:gap-y-0">
      <a href="/#servicios" class="text-center text-[10px] font-semibold uppercase tracking-[0.15em] text-brand-text/40 transition-colors duration-300 hover:text-brand-gold sm:text-[11px] sm:tracking-[0.2em]">Tiradas</a>
      <span class="hidden text-[6px] text-brand-gold/20 sm:inline">◆</span>
      <a href="/sobre" class="text-center text-[10px] font-semibold uppercase tracking-[0.15em] text-brand-text/40 transition-colors duration-300 hover:text-brand-gold sm:text-[11px] sm:tracking-[0.2em]">Sobre nosotros</a>
      <span class="hidden text-[6px] text-brand-gold/20 sm:inline">◆</span>
      <a href="/reservar" class="text-center text-[10px] font-semibold uppercase tracking-[0.15em] text-brand-text/40 transition-colors duration-300 hover:text-brand-gold sm:text-[11px] sm:tracking-[0.2em]">Reservar</a>
      <span class="hidden text-[6px] text-brand-gold/20 sm:inline">◆</span>
      <a href="/#contacto" class="text-center text-[10px] font-semibold uppercase tracking-[0.15em] text-brand-text/40 transition-colors duration-300 hover:text-brand-gold sm:text-[11px] sm:tracking-[0.2em]">Contacto</a>
    </nav>

    <!-- Social -->
    <div class="mt-8 flex items-center justify-center gap-6 sm:mt-10">
      <a href="#" class="group" aria-label="Instagram">
        <svg class="h-4 w-4 text-brand-text/20 transition-all duration-300 group-hover:text-brand-gold group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </a>
      <a href="#" class="group" aria-label="TikTok">
        <svg class="h-4 w-4 text-brand-text/20 transition-all duration-300 group-hover:text-brand-gold group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
      </a>
      <a href="#" class="group" aria-label="WhatsApp">
        <svg class="h-4 w-4 text-brand-text/20 transition-all duration-300 group-hover:text-brand-gold group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
    </div>

    <!-- Contact -->
    <div class="mt-5 flex flex-col items-center gap-1.5 text-[10px] tracking-wide text-brand-text/25 sm:text-[11px] sm:flex-row sm:justify-center sm:gap-4">
      <a href={`mailto:${siteConfig.contact.email}`} class="transition-colors duration-200 hover:text-brand-gold">
        {siteConfig.contact.email}
      </a>
      <span class="hidden text-brand-gold/15 sm:inline">·</span>
      <a href={`tel:+${siteConfig.contact.phone}`} class="transition-colors duration-200 hover:text-brand-gold">
        {formattedPhone}
      </a>
    </div>

    <!-- Bottom divider -->
    <div class="mx-auto mt-10 flex items-center justify-center gap-3 sm:mt-12" aria-hidden="true">
      <span class="h-px w-20 bg-gradient-to-r from-transparent to-brand-gold/10 sm:w-28"></span>
      <span class="h-1 w-1 rounded-full bg-brand-gold/15"></span>
      <span class="h-px w-20 bg-gradient-to-l from-transparent to-brand-gold/10 sm:w-28"></span>
    </div>

    <!-- Legal row -->
    <div class="mt-5 flex flex-col items-center gap-3 text-[10px] tracking-wide text-brand-text/20 sm:flex-row sm:justify-center sm:gap-6">
      <p>&copy; {new Date().getFullYear()} Tarot Divinidad 000</p>
      <div class="flex gap-4">
        <a href="/privacidad" class="transition-colors duration-200 hover:text-brand-gold">Privacidad</a>
        <a href="/aviso-legal" class="transition-colors duration-200 hover:text-brand-gold">Aviso Legal</a>
        <a href="/cookies" class="transition-colors duration-200 hover:text-brand-gold">Cookies</a>
      </div>
    </div>
  </div>
</footer>
