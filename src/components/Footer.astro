---
import { siteConfig } from "../content/site";
import { buildWhatsAppUrl } from "../utils/whatsapp";
import Logo from "./Logo.astro";

const rawPhone = siteConfig.contact.phone;
const whatsappUrl = buildWhatsAppUrl(siteConfig.whatsapp.phone, siteConfig.whatsapp.message);
const formattedPhone =
  rawPhone.length === 11
    ? `+${rawPhone.slice(0, 2)} ${rawPhone.slice(2, 5)} ${rawPhone.slice(5, 8)} ${rawPhone.slice(8)}`
    : `+${rawPhone}`;

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Tiradas & precios", href: "/#servicios" },
  { label: "Reservar", href: "/reservar" },
  { label: "Sobre nosotros", href: "/sobre" },
  { label: "Contacto", href: "/#contacto" },
];

const legalLinks = [
  { label: "Política de privacidad", href: "/privacidad" },
  { label: "Aviso legal", href: "/aviso-legal" },
  { label: "Política de cookies", href: "/cookies" },
];

const socialLinks = {
  instagram: "https://www.instagram.com/divinidad000/",
  facebook: "https://www.facebook.com/profile.php?id=61580637626100",
};
---

<footer class="relative overflow-hidden bg-[#131009]">
  <!-- Ambient glow -->
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_20%_0%,rgba(199,168,90,0.07)_0%,transparent_65%)]"
    aria-hidden="true"
  ></div>

  <!-- Top ornamental border -->
  <div class="relative z-10 flex items-center px-8 sm:px-12" aria-hidden="true">
    <div class="h-px flex-1 bg-gradient-to-r from-transparent via-brand-gold/30 to-brand-gold/50"></div>
    <div class="mx-4 flex items-center justify-center">
          <svg class="h-5 w-5 text-brand-gold/55" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M20 4 L26 16 L36 20 L26 24 L20 36 L14 24 L4 20 L14 16 Z"></path>
        <circle cx="20" cy="20" r="3" fill="currentColor" opacity="0.6" stroke="none"></circle>
      </svg>
    </div>
    <div class="h-px flex-1 bg-gradient-to-l from-transparent via-brand-gold/30 to-brand-gold/50"></div>
  </div>

  <div class="relative z-10 mx-auto w-full max-w-6xl px-6 pt-10 pb-8 sm:px-10 sm:pt-14 md:px-12 md:pt-16 md:pb-10">

    <!-- ── MÓVIL: logo centrado + socials + 2 cols links ── -->
    <!-- ── DESKTOP: 3 columnas lado a lado ── -->

    <!-- ── MÓVIL ── -->
    <div class="md:hidden flex flex-col">

      <!-- 1. Logo + tagline + socials -->
      <div class="flex flex-col items-center text-center gap-4 pb-8">
        <Logo class="opacity-80" svgClass="h-14" />
        <p class="text-[11px] leading-relaxed text-brand-text/50 max-w-[240px]">
          {siteConfig.description}
        </p>
        <div class="flex items-center gap-7">
          <a href={socialLinks.instagram} class="group" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg class="h-5 w-5 text-[#D6B86B] opacity-70 transition-all duration-300 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href={socialLinks.facebook} class="group" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg class="h-5 w-5 text-[#D6B86B] opacity-70 transition-all duration-300 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
          <a href={whatsappUrl} class="group" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
            <svg class="h-5 w-5 text-[#D6B86B] opacity-70 transition-all duration-300 group-hover:opacity-100" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Separador -->
      <div class="flex items-center gap-3 mb-8" aria-hidden="true">
        <div class="h-px flex-1 bg-brand-gold/10"></div>
        <span class="h-1 w-1 rounded-full bg-brand-gold/20"></span>
        <div class="h-px flex-1 bg-brand-gold/10"></div>
      </div>

      <!-- 2. Nav + Legal en 2 columnas centradas -->
      <div class="flex justify-center gap-12 mb-8">
        <div class="flex flex-col gap-3">
          <p class="text-[9px] font-semibold uppercase tracking-[0.3em] text-brand-gold/60 mb-1">Navegación</p>
          <nav class="flex flex-col gap-2.5">
            {navLinks.map((link) => (
              <a href={link.href} class="text-[11px] tracking-wide text-brand-text/55 transition-colors duration-200 hover:text-brand-gold">
                {link.label}
              </a>
            ))}
          </nav>
        </div>
        <div class="flex flex-col gap-3">
          <p class="text-[9px] font-semibold uppercase tracking-[0.3em] text-brand-gold/60 mb-1">Legal</p>
          <div class="flex flex-col gap-2.5">
            {legalLinks.map((link) => (
              <a href={link.href} class="text-[11px] tracking-wide text-brand-text/55 transition-colors duration-200 hover:text-brand-gold">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Separador -->
      <div class="flex items-center gap-3 mb-8" aria-hidden="true">
        <div class="h-px flex-1 bg-brand-gold/10"></div>
        <span class="h-1 w-1 rounded-full bg-brand-gold/20"></span>
        <div class="h-px flex-1 bg-brand-gold/10"></div>
      </div>

      <!-- 3. Horario + Contacto juntos -->
      <div class="flex flex-col items-center gap-3 text-center mb-4">
        <p class="text-[9px] font-semibold uppercase tracking-[0.3em] text-brand-gold/60">Horario y contacto</p>
        <p class="text-[10px] tracking-wide text-brand-text/50">De 10:00 a 12:00 · De 18:00 a 21:00</p>
        <div class="flex flex-col gap-1.5 mt-1">
          <a href={`mailto:${siteConfig.contact.email}`} class="text-[10px] tracking-wide text-brand-text/50 transition-colors duration-200 hover:text-brand-gold">
            {siteConfig.contact.email}
          </a>
          <a href={`tel:+${siteConfig.contact.phone}`} class="text-[10px] tracking-wide text-brand-text/50 transition-colors duration-200 hover:text-brand-gold">
            {formattedPhone}
          </a>
        </div>
      </div>

    </div>

    <!-- ── DESKTOP 3 columnas ── -->
    <div class="hidden md:grid md:grid-cols-3 md:gap-8 lg:gap-16">

      <!-- Col 1: Logo + tagline + socials + back to top -->
      <div class="flex flex-col gap-6">
        <Logo class="opacity-90" />
        <p class="text-[11px] leading-relaxed text-brand-text/55 max-w-[220px]">
          {siteConfig.description}
        </p>
        <div class="flex items-center gap-5">
          <a href={socialLinks.instagram} class="group" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg class="h-[18px] w-[18px] text-[#D6B86B] opacity-75 transition-all duration-300 group-hover:opacity-100 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href={socialLinks.facebook} class="group" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg class="h-[18px] w-[18px] text-[#D6B86B] opacity-75 transition-all duration-300 group-hover:opacity-100 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
          <a href={whatsappUrl} class="group" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
            <svg class="h-[18px] w-[18px] text-[#D6B86B] opacity-75 transition-all duration-300 group-hover:opacity-100 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </a>
        </div>
        <button
          id="back-to-top-desktop"
          aria-label="Volver arriba"
          class="group inline-flex items-center gap-2 self-start border border-brand-gold/20 px-4 py-2 text-[10px] font-semibold uppercase tracking-[0.2em] text-brand-text/55 transition-all duration-300 hover:border-brand-gold/50 hover:text-brand-gold"
        >
          <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"></polyline>
          </svg>
          Volver arriba
        </button>
      </div>

      <!-- Col 2: Mapa del sitio -->
      <div class="flex flex-col gap-5">
        <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-brand-gold/60">Mapa del sitio</p>
        <div class="h-px w-8 bg-brand-gold/20"></div>
        <nav class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a href={link.href} class="group flex items-center gap-2 text-[11px] tracking-wide text-brand-text/60 transition-colors duration-200 hover:text-brand-gold">
              <span class="h-px w-3 bg-brand-gold/30 transition-all duration-300 group-hover:w-5 group-hover:bg-brand-gold/70"></span>
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Col 3: Legal + contacto + crédito -->
      <div class="flex flex-col gap-5">
        <p class="text-[10px] font-semibold uppercase tracking-[0.3em] text-brand-gold/70">Legal</p>
        <div class="h-px w-8 bg-brand-gold/25"></div>
        <div class="flex flex-col gap-3">
          {legalLinks.map((link) => (
            <a href={link.href} class="group flex items-center gap-2 text-[11px] tracking-wide text-brand-text/60 transition-colors duration-200 hover:text-brand-gold">
              <span class="h-px w-3 bg-brand-gold/30 transition-all duration-300 group-hover:w-5 group-hover:bg-brand-gold/70"></span>
              {link.label}
            </a>
          ))}
        </div>
        <div class="mt-2 flex flex-col gap-2">
          <a href={`mailto:${siteConfig.contact.email}`} class="text-[10px] tracking-wide text-brand-text/55 transition-colors duration-200 hover:text-brand-gold">
            {siteConfig.contact.email}
          </a>
          <a href={`tel:+${siteConfig.contact.phone}`} class="text-[10px] tracking-wide text-brand-text/55 transition-colors duration-200 hover:text-brand-gold">
            {formattedPhone}
          </a>
        </div>
        <div class="mt-4 flex flex-col gap-1.5">
          <p class="text-[9px] font-semibold uppercase tracking-[0.3em] text-brand-gold/60">
            Horario de atención
          </p>
          <p class="text-[10px] leading-relaxed tracking-wide text-brand-text/50">
            De 10:00 a 12:00 y de 18:00 a 21:00
          </p>
        </div>
        <p class="mt-auto pt-4 text-[10px] tracking-wide text-brand-text/40">
          Web por <a href="https://gabrielcodes.dev/" target="_blank" rel="noopener noreferrer" class="transition-colors duration-200 hover:text-brand-gold">Gabriel Saiz</a>
        </p>
      </div>

    </div>
  </div>

  <!-- Bottom divider -->
  <div class="relative z-10 mx-auto w-full max-w-6xl px-8 sm:px-12">
    <div class="flex items-center gap-3" aria-hidden="true">
      <div class="h-px flex-1 bg-gradient-to-r from-brand-gold/15 to-transparent"></div>
      <span class="h-1 w-1 rounded-full bg-brand-gold/20"></span>
      <div class="h-px flex-1 bg-gradient-to-l from-brand-gold/15 to-transparent"></div>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="relative z-10 mx-auto w-full max-w-6xl px-6 py-5 sm:px-10 md:px-12">
    <div class="flex flex-col items-center gap-1.5 text-center md:flex-row md:justify-between">
      <p class="text-[10px] tracking-wide text-brand-text/40">
        &copy; {new Date().getFullYear()} Tarot Divinidad 000 · Todos los derechos reservados
      </p>
      <!-- Crédito dev: visible en móvil aquí, en desktop está en col 3 -->
      <p class="text-[10px] tracking-wide text-brand-text/40 md:hidden">
        Web por <a href="https://gabrielcodes.dev/" target="_blank" rel="noopener noreferrer" class="transition-colors duration-200 hover:text-brand-gold">Gabriel Saiz</a>
      </p>
    </div>
  </div>
</footer>

<!-- Back to top flotante — solo móvil -->
<button
  id="back-to-top-mobile"
  aria-label="Volver arriba"
  class="fixed bottom-6 right-6 z-50 flex h-11 w-11 items-center justify-center border border-brand-gold/30 bg-[#131009]/90 text-brand-gold/60 shadow-lg shadow-black/40 backdrop-blur-sm transition-all duration-300 hover:border-brand-gold/70 hover:text-brand-gold md:hidden opacity-0 pointer-events-none translate-y-3"
>
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="18 15 12 9 6 15"></polyline>
  </svg>
</button>

<script>
  function initBackToTop() {
    const btnMobile = document.getElementById("back-to-top-mobile");
    const btnDesktop = document.getElementById("back-to-top-desktop");

    const scrollToTop = () => window.scrollTo({ top: 0, behavior: "smooth" });

    btnMobile?.addEventListener("click", scrollToTop);
    btnDesktop?.addEventListener("click", scrollToTop);

    const onScroll = () => {
      const show = window.scrollY > 400;
      if (btnMobile) {
        btnMobile.classList.toggle("opacity-100", show);
        btnMobile.classList.toggle("pointer-events-auto", show);
        btnMobile.classList.toggle("translate-y-0", show);
        btnMobile.classList.toggle("opacity-0", !show);
        btnMobile.classList.toggle("pointer-events-none", !show);
        btnMobile.classList.toggle("translate-y-3", !show);
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener("astro:page-load", initBackToTop);
  document.addEventListener("DOMContentLoaded", initBackToTop);
</script>
