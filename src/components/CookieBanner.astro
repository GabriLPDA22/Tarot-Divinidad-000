---
---

<div
  id="cookie-banner"
  class="fixed inset-x-0 bottom-0 z-[200] translate-y-full opacity-0 transition-all duration-500 ease-out"
  role="dialog"
  aria-label="Aviso de cookies"
>
  <div class="mx-3 mb-3 sm:mx-auto sm:mb-5 sm:max-w-xl md:max-w-2xl">
      <div class="relative overflow-hidden rounded-2xl border border-brand-gold/15 bg-[#26201B]/95 shadow-2xl shadow-black/60 backdrop-blur-xl">
      <!-- Glow -->
      <div class="pointer-events-none absolute -top-8 left-1/2 h-16 w-32 -translate-x-1/2 rounded-full bg-brand-gold/6 blur-2xl" aria-hidden="true"></div>

      <div class="relative px-4 py-4 sm:px-6 sm:py-5">
        <!-- Row: icon + text -->
        <div class="flex items-start gap-3 sm:items-center sm:gap-4">
          <!-- Cookie icon (always visible) -->
          <div class="shrink-0 pt-0.5 sm:pt-0" aria-hidden="true">
            <svg class="h-8 w-8 text-brand-gold/75 sm:h-9 sm:w-9" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="20" cy="20" r="16"/>
              <circle cx="14" cy="16" r="2" fill="currentColor" stroke="none" opacity="0.9"/>
              <circle cx="24" cy="14" r="1.5" fill="currentColor" stroke="none" opacity="0.8"/>
              <circle cx="18" cy="24" r="2.5" fill="currentColor" stroke="none" opacity="0.9"/>
              <circle cx="26" cy="23" r="1.5" fill="currentColor" stroke="none" opacity="0.75"/>
              <circle cx="20" cy="18" r="1" fill="currentColor" stroke="none" opacity="0.7"/>
            </svg>
          </div>

          <!-- Text -->
          <p class="flex-1 text-xs leading-relaxed text-brand-text/55 sm:text-[13px]">
            Usamos cookies para mejorar tu experiencia. Al continuar, aceptas nuestra
            <a href="/cookies" class="text-brand-gold/60 underline underline-offset-2 transition-colors hover:text-brand-gold">política de cookies</a>.
          </p>
        </div>

        <!-- Buttons row -->
        <div class="mt-3.5 flex gap-2.5 sm:mt-4">
          <button
            id="cookie-reject"
            class="flex-1 rounded-lg border border-brand-text/8 py-2.5 text-[10px] font-semibold uppercase tracking-widest text-brand-text/35 transition-all duration-200 hover:border-brand-text/20 hover:text-brand-text/60 sm:flex-none sm:px-5 sm:py-2 sm:text-[11px]"
          >
            Rechazar
          </button>
          <button
            id="cookie-accept"
            class="flex-1 rounded-lg bg-brand-gold py-2.5 text-[10px] font-semibold uppercase tracking-widest text-brand-bg transition-all duration-200 hover:bg-brand-gold-light hover:shadow-lg hover:shadow-brand-gold/20 sm:flex-none sm:px-6 sm:py-2 sm:text-[11px]"
          >
            Aceptar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var consent = localStorage.getItem("cookie-consent");
    if (consent) return;

    var banner = document.getElementById("cookie-banner");
    if (!banner) return;

    var shown = false;
    function showBanner() {
      if (shown) return;
      shown = true;
      banner.style.transform = "translateY(0)";
      banner.style.opacity = "1";
    }

    // Si el loader está activo, esperamos su evento de finalización.
    // Si no, mostramos el banner inmediatamente.
    if (document.querySelector(".loader-overlay")) {
      document.addEventListener("loader:done", showBanner, { once: true });
      // Fallback por si el evento no llegara por cualquier motivo
      setTimeout(showBanner, 2600);
    } else {
      requestAnimationFrame(showBanner);
    }

    function hide() {
      banner.style.transform = "translateY(100%)";
      banner.style.opacity = "0";
      setTimeout(function () { banner.remove(); }, 500);
    }

    document.getElementById("cookie-accept").addEventListener("click", function () {
      localStorage.setItem("cookie-consent", "accepted");
      hide();
    });

    document.getElementById("cookie-reject").addEventListener("click", function () {
      localStorage.setItem("cookie-consent", "rejected");
      hide();
    });
  })();
</script>
